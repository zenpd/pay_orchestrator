APP_ENV=development
APP_SECRET_KEY=dev-secret-key-change-in-production
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/payment_orchestrator
REDIS_URL=redis://localhost:6379/0

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure Key Vault
AZURE_KEYVAULT_URL=https://zaf-kv-01.vault.azure.net/

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Phoenix Observability
PHOENIX_HOST=localhost
PHOENIX_PORT=6006
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT_NAME=payment-orchestration

# Temporal (Optional)
TEMPORAL_ENABLED=false
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=payment-orchestrator

# Payment Processing
PAYMENT_RAILS_API_KEY=mock
PAYMENT_RAILS_API_URL=http://localhost:8080
PAYMENT_RAILS_TIMEOUT_SECONDS=30
